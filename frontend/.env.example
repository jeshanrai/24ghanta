# Backend API base URL. Used at build time for SSR fetches and at runtime for
# image rendering (next/image remotePatterns is built from this).
# Local development: http://localhost:5000
# Production:        https://24ghanta-api.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:5000

# Public site origin — used for robots.txt + sitemap.xml absolute URLs.
# Local development: http://localhost:3000
# Production:        https://www.24ghanta.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
