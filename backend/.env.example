# ─── Database ───────────────────────────────────────────────
# Neon: copy the "Pooled connection" string from the Neon console.
# SSL is enabled automatically whenever the host is not localhost.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require

# Optional overrides (default: auto — on for remote, off for localhost)
# DB_SSL=true
# DB_SSL=false

# ─── Server ─────────────────────────────────────────────────
# Render provides PORT automatically; leave blank in production.
PORT=5000
NODE_ENV=development

# ─── CORS ───────────────────────────────────────────────────
# Production Vercel domain. Comma-separated list also allowed:
# FRONTEND_URL=https://24ghanta.vercel.app,https://www.24ghanta.com
FRONTEND_URL=http://localhost:3000

# Set to true to additionally allow *.vercel.app preview deployments
VERCEL_PREVIEW=false

# ─── Auth ───────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# ─── Startup ────────────────────────────────────────────────
# Apply schema.sql on server start (idempotent — CREATE TABLE IF NOT EXISTS).
# Set to false once schema is stable and you prefer manual migrations.
AUTO_MIGRATE=true

# Seed mock data on first start (skipped automatically if categories already exist).
AUTO_SEED=true
