# ─── Database ───────────────────────────────────────────────
# Neon: copy the "Pooled connection" string from the Neon console.
# SSL is enabled automatically whenever the host is not localhost.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require

# Optional overrides (default: auto — on for remote, off for localhost)
# DB_SSL=true
# DB_SSL=false

# ─── Server ─────────────────────────────────────────────────
# Render provides PORT automatically; leave blank in production.
PORT=5000
NODE_ENV=development

# ─── CORS ───────────────────────────────────────────────────
# Production Vercel domain. Comma-separated list also allowed:
# FRONTEND_URL=https://24ghanta.vercel.app,https://www.24ghanta.com
FRONTEND_URL=http://localhost:3000

# Set to true to additionally allow *.vercel.app preview deployments
VERCEL_PREVIEW=false

# ─── Auth ───────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# ─── Production seed (read by `npm run seed:prod`) ──────────
# Override these for the very first seed run, then rotate via the admin UI.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-this-strong-password
SEED_AUTHOR_PASSWORD=replace-this-default-author-password

# ─── Startup ────────────────────────────────────────────────
# Apply schema.sql on server start (idempotent — CREATE TABLE IF NOT EXISTS).
# DEV default: true.  PROD default: FALSE (must be explicitly enabled).
# In production prefer running migrations as a one-off job, not on every boot
# (multi-instance deploys can race; an accidental schema change can corrupt data).
AUTO_MIGRATE=true

# Seed mock data on first start (skipped automatically if categories already exist).
# DEV default: true.  PROD default: FALSE.
AUTO_SEED=true
